APP_ENV=local
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4.1-nano
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
ENABLED_PERSONAS=kardec
DATABASE_URL=postgresql+psycopg://ai:ai@localhost:5532/ai

# Comma-separated browser origins allowed by CORS.
# Local/test default to localhost Vite origins when this is empty.
# Production must set explicit HTTPS origins and must not use "*".
BACKEND_CORS_ORIGINS=

# Supabase Auth verification.
# SUPABASE_JWT_SECRET supports existing HS256 Supabase JWT projects.
# If omitted, the backend uses SUPABASE_URL JWKS verification for asymmetric keys.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_VERIFY_ISSUER=true
